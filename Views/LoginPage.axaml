<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Logistiсs.Views.LoginPage">

    <StackPanel Margin="40" Spacing="10">

        <TextBlock Text="Вхід"
                   FontSize="24"/>

        <TextBox PlaceholderText="ПІБ"/>

        <TextBox PlaceholderText="Пароль"/>

        <Button Classes = "gradient" Content="Увійти"
                         Click="LoginClick"/>

    </StackPanel>

</UserControl>